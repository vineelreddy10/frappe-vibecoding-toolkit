{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MCP Config",
  "type": "object",
  "required": ["version", "mcps"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string"
    },
    "mcps": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": {
            "type": "string",
            "description": "Unique identifier for the MCP"
          },
          "description": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["npm", "git", "remote", "local"],
            "description": "Installation type"
          },
          "repo": {
            "type": "string",
            "format": "uri",
            "description": "Git repository URL"
          },
          "package": {
            "type": "string",
            "description": "NPM package name with version"
          },
          "url": {
            "type": "string",
            "format": "uri",
            "description": "Remote MCP endpoint URL"
          },
          "command": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Command to run for local MCPs"
          },
          "headers": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "required": {
            "type": "boolean",
            "default": false
          }
        }
      }
    },
    "opencode_config": {
      "type": "object",
      "properties": {
        "config_path": { "type": "string" },
        "oh_my_opencode_path": { "type": "string" },
        "skills_path": { "type": "string" }
      }
    }
  }
}
